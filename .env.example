# Port the web UI is available on (default: 80)
WEB_PORT=80

# Port the Python backend listens on — must match what the browser can reach
# Change both this and BACKEND_PORT if 4000 is already in use
BACKEND_PORT=4000

# How often (seconds) the backend SSHes into machines to collect stats
POLL_INTERVAL=30

# SSH connection timeout in seconds
SSH_TIMEOUT=10

# Optional: pin a secret key for the backend (auto-generated on first start if unset)
# HOMELAB_SECRET_KEY=replace-with-a-long-random-string
